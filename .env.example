# --- App ---
APP_ENV=dev

# --- Auth ---
SECRET_KEY=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://claimpilot:claimpilot@localhost:5432/claimpilot
REDIS_URL=redis://localhost:6379/0

# --- LLM secrets ---
# Provider choice, model names, endpoints (including a local OpenAI-compatible
# server's URL), temperature, and token budgets live in configs/models.yaml, not
# here — this file holds only the API keys/secrets for whichever provider is active.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
LOCAL_LLM_API_KEY=

# --- External services ---
CRM_BASE_URL=http://localhost:8001
