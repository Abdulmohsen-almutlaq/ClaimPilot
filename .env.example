# --- App ---
APP_ENV=dev

# --- Auth ---
SECRET_KEY=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://claimpilot:claimpilot@localhost:5432/claimpilot
REDIS_URL=redis://localhost:6379/0

# --- LLM provider: anthropic | openai | local ---
# The app/llm client wrapper (M3) reads LLM_PROVIDER and switches providers with
# no code changes. "local" targets any OpenAI-compatible server you run yourself.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Any OpenAI-compatible local server: Ollama (http://localhost:11434/v1),
# vLLM, LM Studio, etc. Set LLM_PROVIDER=local to use these instead.
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=

# --- External services ---
CRM_BASE_URL=http://localhost:8001
